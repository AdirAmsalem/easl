{
  "name": "@easl/mcp",
  "version": "0.1.0",
  "description": "easl MCP server — turn agent output into pages worth sharing",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AdirAmsalem/easl.git",
    "directory": "packages/mcp-server"
  },
  "type": "module",
  "author": "Adir Amsalem",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.mjs",
  "files": [
    "dist"
  ],
  "bin": {
    "mcp": "dist/index.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "agent",
    "publish",
    "hosting"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "start": "node dist/index.mjs",
    "typecheck": "tsc --noEmit",
    "release": "bumpp --tag 'mcp@%s'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "bumpp": "^10.1.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.7.0"
  }
}
