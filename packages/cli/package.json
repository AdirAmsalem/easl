{
  "name": "@easl/cli",
  "version": "0.1.0",
  "description": "easl CLI — instant hosting from your terminal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AdirAmsalem/easl.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "author": "Adir Amsalem",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "easl": "./dist/cli.cjs"
  },
  "files": [
    "dist/cli.cjs"
  ],
  "keywords": [
    "cli",
    "easl",
    "hosting",
    "publish",
    "ai",
    "agent"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.config.e2e.mts",
    "release": "bumpp --tag 'cli@%s'"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "commander": "^14.0.0",
    "picocolors": "^1.1.1",
    "@clack/prompts": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "bumpp": "^10.1.0",
    "vitest": "^4.1.0"
  }
}
