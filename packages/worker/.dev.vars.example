# Copy to .dev.vars (gitignored) for local development with `wrangler dev`.
# SESSION_SECRET signs unlock cookies for private easls. Use any long random string
# locally (>= 16 chars). Generate one with: openssl rand -base64 48
# Private sites fail closed if this is unset or left as the literal placeholder below.
SESSION_SECRET="local-dev-session-secret-change-me-please"
